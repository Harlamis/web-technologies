{
  "name": "web-technologies",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "watch:html": "onchange \"**/*.html\" -- npm run lint:html",
    "watch:css": "onchange \"**/*.css\" -- npm run lint:css",
    "watch:all": "concurrently \"npm run watch:html\" \"npm run watch:css\""
  },
  "dependencies": {
    "normalize.css": "^8.0.1"
  },
  "devDependencies": {
    "htmlhint": "^1.7.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "onchange": "^7.1.0",
    "concurrently": "^8.2.0"
  }
}
